# Folio — 환경변수 템플릿
# 이 파일을 복사해 .env.local로 만들고 실제 값을 채워넣으세요:
#   cp .env.example .env.local

# ─────────────────────────────────────────────────────────
# Supabase — DB / 인증 / Storage
#   - URL/ANON_KEY: 클라이언트(브라우저)에서 사용 (NEXT_PUBLIC_)
#   - SERVICE_ROLE_KEY: 서버 사이드 전용 (RLS 우회). 절대 클라이언트로 노출 금지
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────
# Database — Postgres 직접 접근 (Prisma/Drizzle 등 ORM용, 선택)
#   Supabase 대시보드 > Project Settings > Database > Connection string
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────
# 외부 서비스 (선택 — 필요 시 주석 해제)
# ─────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sentry 에러 트래킹 (운영 권장)
#   - DSN은 Sentry 프로젝트 → Settings → Client Keys (DSN)
#   - AUTH_TOKEN은 Source Map 업로드용. User Auth Tokens → project:releases + project:read 권한
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ─────────────────────────────────────────────────────────
# 미수채권 학교담당자 독려 메일 (Microsoft Graph sendMail)
#   - 발신은 로그인한 운영자 본인 메일박스에서 (operators.email = Azure AD UPN 가정)
#   - Azure AD App에 Mail.Send Application permission + admin consent 필요
#   - MAIL_DRY_RUN=true 면 실제 발송 대신 receivables_mail_sends 에 status='dry_run' 만 기록
# ─────────────────────────────────────────────────────────
MAIL_COMPANY_NAME=진학어플라이
MAIL_REMINDER_THRESHOLD_DAYS=10
MAIL_DRY_RUN=true

# ─────────────────────────────────────────────────────────
# 미수채권 자동화 — 운영자 알림 + 입금 매칭 (4-PR 시리즈, GAS 폐기)
#   - 운영자 알림: 평일 10시 cron (receivables-mail-operator)
#     · MAIL_DRY_RUN(위) 공유
#   - 입금 매칭: 매시간 cron (receivables-deposit-match)
#     · SHAREPOINT_DEPOSIT_ITEM_ID: 입금내역 Excel item (운영팀과 조율)
#     · MAIL_MATCH_DRY_RUN=true 면 PATCH skip, receivables_match_runs에 mode='dry_run' 만 적재
#   - cron 진입점: /api/automations/run (Authorization: Bearer CRON_SECRET)
# ─────────────────────────────────────────────────────────
SHAREPOINT_DEPOSIT_ITEM_ID=01XXXXXXXXXXXXXXXXXX
MAIL_MATCH_DRY_RUN=true
# GitHub Actions cron이 호출할 OPS-Console 배포 URL (https://ops-console.vercel.app 등)
OPS_CONSOLE_BASE_URL=https://ops-console.example.com

# ─────────────────────────────────────────────────────────
# 예약 자료요청 dispatch 인증 (Cron)
#   - 예약 자료요청 dispatch 인증용 — Supabase pg_cron의 net.http_post가 x-cron-secret 헤더로 전송.
#   - Vercel 환경변수 + cron.schedule SQL에 동일 값 설정.
# ─────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────
# GitHub Actions 워크플로 트리거 (closing-scrape 자동화 잡 → OPS가 GitHub dispatch)
#   - SmileEDI(워크플로→OPS)와 반대 방향. closing-scrape 잡의 run()이 사용.
#   - PAT: Fine-grained, 해당 repo, 권한 Actions = Read and write.
#   - 누락 시 closing-scrape 잡이 ok:false (폴백 없음).
# ─────────────────────────────────────────────────────────
GITHUB_DISPATCH_TOKEN=
GITHUB_DISPATCH_REPO=owner/repo
GITHUB_DISPATCH_WORKFLOW=moa-closing-scrape.yml

# ─────────────────────────────────────────────────────────
# SharePoint 계약서 Excel (Microsoft Graph workbook read)
#   - contracts 메뉴(/dashboard/contracts)에서 4년제~기타 5 시트 통합 read-only 조회
#   - AZURE_AD_* + SHAREPOINT_DRIVE_ID는 receivables/backup 도메인과 공유 (별도 항목)
# ─────────────────────────────────────────────────────────
SHAREPOINT_CONTRACTS_ITEM_ID=01XXXXXXXXXXXXXXXXXX

# 운영 매뉴얼 폴더 (운영부/05. 매뉴얼) — /dashboard/manuals 메뉴 root
SHAREPOINT_MANUAL_ITEM_ID=01XXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────
# Gemini (Google AI) — AI 어시스턴트 메뉴 (/dashboard/ai-assistant)
#   - 사내 데이터(사고·인수인계·TIP·백업·연락처·서비스) + 자연어 Q&A
#   - https://aistudio.google.com/app/apikey 에서 발급 (무료 tier 가능)
#   - 모델: gemini-2.0-flash (저렴 + 빠름 + 1M context)
# ─────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────
# 앱 설정
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
