# Folio — 환경변수 템플릿
# 이 파일을 복사해 .env.local로 만들고 실제 값을 채워넣으세요:
#   cp .env.example .env.local

# ─────────────────────────────────────────────────────────
# Supabase — DB / 인증 / Storage
#   - URL/ANON_KEY: 클라이언트(브라우저)에서 사용 (NEXT_PUBLIC_)
#   - SERVICE_ROLE_KEY: 서버 사이드 전용 (RLS 우회). 절대 클라이언트로 노출 금지
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────
# Database — Postgres 직접 접근 (Prisma/Drizzle 등 ORM용, 선택)
#   Supabase 대시보드 > Project Settings > Database > Connection string
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────
# 외부 서비스 (선택 — 필요 시 주석 해제)
# ─────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ─────────────────────────────────────────────────────────
# 미수채권 학교담당자 독려 메일 (Microsoft Graph sendMail)
#   - 발신은 로그인한 운영자 본인 메일박스에서 (operators.email = Azure AD UPN 가정)
#   - Azure AD App에 Mail.Send Application permission + admin consent 필요
#   - MAIL_DRY_RUN=true 면 실제 발송 대신 receivables_mail_sends 에 status='dry_run' 만 기록
# ─────────────────────────────────────────────────────────
MAIL_COMPANY_NAME=진학어플라이
MAIL_REMINDER_THRESHOLD_DAYS=10
MAIL_DRY_RUN=true

# ─────────────────────────────────────────────────────────
# 예약 자료요청 dispatch 인증 (Cron)
#   - 예약 자료요청 dispatch 인증용 — Supabase pg_cron의 net.http_post가 x-cron-secret 헤더로 전송.
#   - Vercel 환경변수 + cron.schedule SQL에 동일 값 설정.
# ─────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────
# SharePoint 계약서 Excel (Microsoft Graph workbook read)
#   - contracts 메뉴(/dashboard/contracts)에서 4년제~기타 5 시트 통합 read-only 조회
#   - AZURE_AD_* + SHAREPOINT_DRIVE_ID는 receivables/backup 도메인과 공유 (별도 항목)
# ─────────────────────────────────────────────────────────
SHAREPOINT_CONTRACTS_ITEM_ID=01XXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────
# 앱 설정
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
